# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
playwright-report/
test-results/
blob-report/
homepage.png

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code (local/personal config only — shared config lives in .claude/settings.json and .claude/skills/)
.claude/settings.local.json

# local QA artifacts (kept on disk, not versioned)
screenshots-review/

# typescript
*.tsbuildinfo
next-env.d.ts
